# Web App Environment Variables

# API URL - Point to your deployed backend API
NEXT_PUBLIC_API_URL=https://tarantuverse-api.onrender.com

# For local development, use:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth.js Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-key-here
NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://tarantuverse.com

# Google OAuth (Required)
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (Optional - for Sign In with Apple)
# Get these from: https://developer.apple.com/account/
APPLE_CLIENT_ID=com.tarantuverse.web
APPLE_CLIENT_SECRET=generate-using-apple-private-key
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
# Apple Private Key (.p8 file contents - keep secure!)
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----"

# PostHog Analytics (Optional — leave unset to disable)
# Create a project at https://us.posthog.com and copy the Project API Key.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
# Defaults route through /ingest (same-origin proxy in next.config.js) so
# events survive ad blockers. Only override if you know what you're doing.
# NEXT_PUBLIC_POSTHOG_HOST=/ingest
# NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
