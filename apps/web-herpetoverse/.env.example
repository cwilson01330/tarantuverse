# Herpetoverse Web Environment Variables

# API URL — Point to the shared Tarantuverse backend.
NEXT_PUBLIC_API_URL=https://tarantuverse-api.onrender.com

# For local development:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# PostHog Analytics (Optional — leave unset to disable)
# Create a project at https://us.posthog.com and copy the Project API Key.
# Use the SAME project as Tarantuverse web so cross-app user journeys
# resolve to one identity (we identify by user.id which is shared).
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
# Optional override; defaults to the US cloud host.
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
