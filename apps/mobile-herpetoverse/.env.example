# Herpetoverse Mobile Environment Variables

# API URL — shared Tarantuverse backend.
EXPO_PUBLIC_API_URL=https://tarantuverse-api.onrender.com

# For local development against a local backend:
# EXPO_PUBLIC_API_URL=http://192.168.x.x:8000

# PostHog Analytics (Optional — leave unset to disable)
# Use the SAME project as the two web apps so cross-platform user journeys
# resolve to one identity. We segment surfaces by the `app` person-property
# (automatically set to "herpetoverse-mobile" in src/services/posthog.ts).
EXPO_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here

# Optional — defaults to US cloud.
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
