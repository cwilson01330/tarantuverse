# Normalize all text files to LF on commit, regardless of OS
* text=auto eol=lf

# Explicitly mark file types as text (normalized)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.env text eol=lf
*.sql text eol=lf

# Binary files - never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Lock files - keep as-is
pnpm-lock.yaml -diff
